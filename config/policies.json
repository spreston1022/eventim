{
  "policies": [
    {
      "name": "dynamic-jwks-auth",
      "policyType": "custom-code-inbound",
      "handler": {
        "export": "dynamicJwksAuthPolicy",
        "module": "$import(./modules/dynamic-jwks-policy)",
        "options": {
          "issuerPrefixes": [
            "http://localhost:9000/mock-idp/realms/",
            "https://eventim-poc-main-9473b72.d2.zuplo.dev/mock-idp/realms/",
            "https://eventim-poc-main-eb180b4.zuplo.app/mock-idp/realms/"
          ],
          "audience": "https://api.eventim-dummy.com"
        }
      }
    },
    {
      "name": "eventim-jwks-auth-test",
      "policyType": "custom-code-inbound",
      "handler": {
        "export": "eventimJwksAuthPolicy",
        "module": "$import(./modules/eventim-jwks-policy)",
        "options": {
          "issuerPrefixes": [
            "http://localhost:9000",
            "https://eventim-poc-main-eb180b4.zuplo.app",
            "https://eventim-poc-main-9473b72.d2.zuplo.dev"
          ],
          "jwksTemplate": "/mock-idp/realms/${realm}/protocol/openid-connect/certs"
        }
      }
    },
    {
      "name": "fetch-span-test",
      "policyType": "custom-code-inbound",
      "handler": {
        "export": "fetchSpanTestPolicy",
        "module": "$import(./modules/fetch-span-test-policy)"
      }
    }
  ]
}
